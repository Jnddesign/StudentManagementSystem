<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.student.LoginController"
      alignment="CENTER"
      spacing="0"
      style="-fx-background-color: #1a237e;">

    <!-- Card -->
    <VBox alignment="CENTER" spacing="18"
          style="-fx-background-color: white; -fx-background-radius: 12;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 16, 0, 0, 4);"
          maxWidth="380">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <!-- Icon / Title -->
        <Label text="🎓"
               style="-fx-font-size: 48px;"/>
        <Label text="Student Management System"
               alignment="CENTER"
               wrapText="true"
               style="-fx-font-size: 16px; -fx-font-weight: bold;
                      -fx-text-fill: #1a237e; -fx-font-family: 'Segoe UI';"/>
        <Label text="Please log in to continue"
               style="-fx-font-size: 12px; -fx-text-fill: #9e9e9e;
                      -fx-font-family: 'Segoe UI';"/>

        <!-- Divider -->
        <Separator prefWidth="300"/>

        <!-- Username -->
        <VBox spacing="5" maxWidth="300">
            <Label text="Username"
                   style="-fx-font-weight: bold; -fx-font-size: 12px;
                          -fx-text-fill: #424242; -fx-font-family: 'Segoe UI';"/>
            <TextField fx:id="txtUsername"
                       promptText="Enter username"
                       prefWidth="300"
                       style="-fx-font-size: 13px; -fx-padding: 8;
                              -fx-border-color: #c5cae9; -fx-border-radius: 6;
                              -fx-background-radius: 6;"/>
        </VBox>

        <!-- Password -->
        <VBox spacing="5" maxWidth="300">
            <Label text="Password"
                   style="-fx-font-weight: bold; -fx-font-size: 12px;
                          -fx-text-fill: #424242; -fx-font-family: 'Segoe UI';"/>
            <PasswordField fx:id="txtPassword"
                           promptText="Enter password"
                           prefWidth="300"
                           style="-fx-font-size: 13px; -fx-padding: 8;
                                  -fx-border-color: #c5cae9; -fx-border-radius: 6;
                                  -fx-background-radius: 6;"/>
        </VBox>

        <!-- Error label -->
        <Label fx:id="lblError" text=""
               style="-fx-text-fill: #c62828; -fx-font-size: 12px;
                      -fx-font-family: 'Segoe UI';"/>

        <!-- Login Button -->
        <Button text="Login"
                onAction="#handleLogin"
                prefWidth="300"
                style="-fx-background-color: #1a237e; -fx-text-fill: white;
                       -fx-font-size: 14px; -fx-font-weight: bold;
                       -fx-background-radius: 6; -fx-cursor: hand;
                       -fx-padding: 10;"/>

        <!-- Hint -->
        <Label text="Default: admin / admin123"
               style="-fx-font-size: 11px; -fx-text-fill: #bdbdbd;
                      -fx-font-family: 'Segoe UI';"/>
    </VBox>
</VBox>

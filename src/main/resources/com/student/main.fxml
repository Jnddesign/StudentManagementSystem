<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.student.Controller"
      spacing="15"
      style="-fx-background-color: #f4f6fb; -fx-font-family: 'Segoe UI', Arial, sans-serif;">

    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <!-- ── Title ─────────────────────────────────────────────────────────── -->
    <Label text="Student Record Management System"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a237e;"/>

    <!-- ── Input Form ─────────────────────────────────────────────────────── -->
    <GridPane hgap="12" vgap="10"
              style="-fx-background-color: white; -fx-background-radius: 8;
                     -fx-border-color: #e0e0e0; -fx-border-radius: 8;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 4, 0, 0, 2);">
        <padding>
            <Insets top="16" right="16" bottom="16" left="16"/>
        </padding>

        <!-- Row 0: Section label -->
        <Label text="Student Information"
               style="-fx-font-weight: bold; -fx-text-fill: #3949ab; -fx-font-size: 13px;"
               GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="4"/>

        <!-- Row 1: Name -->
        <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"
               style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtName" promptText="Full name"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"
                   prefWidth="200"/>

        <!-- Row 1: Course (same row, columns 2-3) -->
        <Label text="Course:" GridPane.columnIndex="2" GridPane.rowIndex="1"
               style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtCourse" promptText="e.g. BSCS, BSIT"
                   GridPane.columnIndex="3" GridPane.rowIndex="1"
                   prefWidth="180"/>

        <!-- Row 2: Year Level -->
        <Label text="Year Level:" GridPane.columnIndex="0" GridPane.rowIndex="2"
               style="-fx-font-weight: bold;"/>
        <ChoiceBox fx:id="cbYear" prefWidth="200"
                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <!-- Column constraints so the grid stretches nicely -->
        <columnConstraints>
            <ColumnConstraints minWidth="80" prefWidth="90"/>
            <ColumnConstraints minWidth="160" prefWidth="210" hgrow="ALWAYS"/>
            <ColumnConstraints minWidth="80" prefWidth="90"/>
            <ColumnConstraints minWidth="160" prefWidth="210" hgrow="ALWAYS"/>
        </columnConstraints>
    </GridPane>

    <!-- ── Button Row ─────────────────────────────────────────────────────── -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="➕  Add"
                onAction="#addStudent"
                prefWidth="110"
                style="-fx-background-color: #3949ab; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 6;
                       -fx-cursor: hand;"/>
        <Button text="✏️  Update"
                onAction="#updateStudent"
                prefWidth="110"
                style="-fx-background-color: #f57c00; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 6;
                       -fx-cursor: hand;"/>
        <Button text="🗑️  Delete"
                onAction="#deleteStudent"
                prefWidth="110"
                style="-fx-background-color: #c62828; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 6;
                       -fx-cursor: hand;"/>
        <Button text="✖  Clear"
                onAction="#clearFields"
                prefWidth="110"
                style="-fx-background-color: #546e7a; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 6;
                       -fx-cursor: hand;"/>
    </HBox>

    <!-- ── Status Label ───────────────────────────────────────────────────── -->
    <Label fx:id="lblStatus" text=""
           style="-fx-font-size: 12px; -fx-text-fill: #388e3c;"/>

    <!-- ── TableView ──────────────────────────────────────────────────────── -->
    <TableView fx:id="table" VBox.vgrow="ALWAYS"
               style="-fx-background-color: white; -fx-border-color: #e0e0e0;
                      -fx-border-radius: 8; -fx-background-radius: 8;">
        <columns>
            <TableColumn fx:id="colId"     text="ID"         prefWidth="55"/>
            <TableColumn fx:id="colName"   text="Name"       prefWidth="210"/>
            <TableColumn fx:id="colCourse" text="Course"     prefWidth="160"/>
            <TableColumn fx:id="colYear"   text="Year Level" prefWidth="130"/>
        </columns>
        <placeholder>
            <Label text="No student records found. Add one above!"
                   style="-fx-text-fill: #9e9e9e;"/>
        </placeholder>
    </TableView>

    <!-- ── Footer ─────────────────────────────────────────────────────────── -->
    <Label text="💡 Tip: Click a row to select it, then edit the fields and press Update or Delete."
           style="-fx-font-size: 11px; -fx-text-fill: #78909c;"/>

</VBox>
